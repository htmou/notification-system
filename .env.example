# =============================================================================
# Fichier de configuration exemple — ocp-ml-monitoring-system
# =============================================================================
# Pour configurer le projet :
#   1. Copiez ce fichier et renommez la copie en ".env"
#   2. Remplacez chaque valeur fictive par votre valeur réelle
#   3. Ne versionnez jamais le fichier ".env" (il est exclu par .gitignore)
# =============================================================================


# -----------------------------------------------------------------------------
# Configuration email (lecture IMAP)
# -----------------------------------------------------------------------------
# Serveur IMAP de votre fournisseur de messagerie.
# Pour Gmail : imap.gmail.com (port 993, SSL activé par défaut)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Adresse email utilisée pour la lecture des messages entrants
EMAIL_ADDRESS=your_email@gmail.com

# Mot de passe d'application (à générer depuis les paramètres de sécurité
# de votre compte Google — ne pas utiliser le mot de passe principal du compte)
EMAIL_PASSWORD=your_16_character_app_password_here

# Dossiers IMAP à surveiller — liste séparée par des virgules (INBOX par défaut)
# Exemple pour surveiller plusieurs dossiers : IMAP_FOLDERS=INBOX,Alertes,Sent
IMAP_FOLDERS=INBOX


# -----------------------------------------------------------------------------
# Configuration WhatsApp (Green API)
# -----------------------------------------------------------------------------
# Identifiant de l'instance Green API (visible dans la console green-api.com)
# Format : entier numérique, ex. 1101234567
GREENAPI_INSTANCE_ID=1101234567

# Token API de l'instance Green API (visible dans la console green-api.com)
# L'instance doit être en statut "Online" (liée via QR code) pour que les
# envois fonctionnent. Une instance déconnectée produit un échec HTTP loggé,
# jamais un crash du pipeline.
GREENAPI_API_TOKEN=your_green_api_token_here


# -----------------------------------------------------------------------------
# Destinataires WhatsApp (groupes natifs Green API)
# -----------------------------------------------------------------------------
# Convention de nommage : WHATSAPP_GROUP_<NOM>=<chatId>
#
# Le suffixe <NOM> (en majuscules) est converti en minuscules et devient la clé
# dans get_whatsapp_groups(). Cette clé doit correspondre à la valeur "target:"
# définie dans config/routing_rules.yaml pour que le routage fonctionne.
#
# Exemples de correspondance :
#   WHATSAPP_GROUP_URGENT      → clé "urgent"      → target: urgent   dans YAML
#   WHATSAPP_GROUP_MAINTENANCE → clé "maintenance" → target: maintenance dans YAML
#   WHATSAPP_GROUP_GENERAL     → clé "general"     → target: general  dans YAML
#
# Pour ajouter un groupe : déclarez une nouvelle variable WHATSAPP_GROUP_<NOM>
# et ajoutez la règle cible correspondante dans routing_rules.yaml — aucune
# modification du code source n'est nécessaire.
#
# Format groupe     : <groupId>@g.us  (ex. 120363000000000001@g.us)
# Format individuel : <number>@c.us   (ex. 212600000001@c.us, sans le +)
# Les identifiants de groupe s'obtiennent via l'endpoint getContacts de Green API
# ou depuis l'interface WhatsApp (Infos du groupe → Lien d'invitation).
WHATSAPP_GROUP_URGENT=120363000000000001@g.us
WHATSAPP_GROUP_MAINTENANCE=120363000000000002@g.us
WHATSAPP_GROUP_GENERAL=120363000000000003@g.us


# -----------------------------------------------------------------------------
# Configuration des logs
# -----------------------------------------------------------------------------
# Niveau de verbosité des logs : DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Chemin du fichier de log d'audit (relatif à la racine du projet)
LOG_FILE=logs/audit.log


# -----------------------------------------------------------------------------
# Environnement d'exécution
# -----------------------------------------------------------------------------
# Valeurs possibles : development, production
# En mode "development" : logs plus verbeux, validations assouplies
# En mode "production" : logs minimaux, validations strictes
APP_ENV=production

# Intervalle de vérification de la boîte mail en secondes
POLLING_INTERVAL_SECONDS=10